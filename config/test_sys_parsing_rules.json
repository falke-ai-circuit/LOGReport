{"regex_patterns": {"ip_address": "set XD_IP_ADDR=([0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3})", "ap_node": "^:e:hw:(?P<lid>[0-9a-fA-F]{2,4})\\s+(?P<node_name>AP\\d{2})(?:m|r|t)?\\d*\\s+.*", "al_node": "^:e:hw:(?P<lid>[0-9a-fA-F]{2,4})\\s+(?P<node_name>AL\\d{2})\\s+(?:pxe:sys-csg2)?.*", "token_entry": "^:e:hw:(?P<lid>[0-9a-fA-F]{2,4})\\s+(?P<node_prefix>(?:AP|AL)\\d{2})(?P<suffix>(?:_m|_r|_t)?\\d*)?\\s+.*"}, "node_types": {"ap_based": {"default_types": ["AP"], "token_suffixes": ["_m2", "_m3", "_r2", "_r3"]}, "al_based": {"default_types": ["AL", "LIS"]}}}